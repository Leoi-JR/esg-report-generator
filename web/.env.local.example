# Web 平台环境变量配置示例
# 复制为 .env.local 并填入实际值

# ── Pipeline UI 调试模式 ──────────────────────────────────────────────────────
# 显示每个阶段的文字标签（true = 开启，false/不设 = 关闭）
NEXT_PUBLIC_PIPELINE_DEBUG_UI=false

# ── LLM API（AI 辅助功能：润色、续写、核查等） ───────────────────────────────
# 与项目根 .env 保持一致；Web 端 AI 功能通过此配置调用 LLM
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-v3
