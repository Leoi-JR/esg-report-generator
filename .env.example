# ==============================================================================
# ESG 报告生成系统 — 环境变量配置
# ==============================================================================
# 复制此文件为 .env 并填入真实值。.env 已加入 .gitignore，不会提交到仓库。

# ── DashScope API（Embedding / Reranker / VLM 服务共用） ─────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ── Embedding 配置（DashScope text-embedding-v4）─────────────────────────
# API 限制：单次最多 10 条文本，无明确 RPM/TPM 限制
# EMBEDDING_BATCH_SIZE  每批文本数（DashScope 单次上限 10）
# EMBEDDING_CONCURRENCY 并发请求数（多批同时提交）
# EMBEDDING_DIM         向量维度（text-embedding-v4 支持 768/1024/2048）
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=2048
EMBEDDING_BATCH_SIZE=10
EMBEDDING_CONCURRENCY=20

# ── Embedding 服务地址（默认本地 embedding_server.py 适配层） ────────────
# OPENAI_BASE_URL=http://localhost:8081/v1

# ── 智谱 GLM-OCR API ───────────────────────────────────────────────────
# 用于扫描件 PDF 和表格截图的文档解析（layout_parsing）
# API 限制：未公开具体 RPM/TPM，并发建议保守设置
ZHIPU_API_KEY=your-zhipu-api-key-here

# ── VLM 图片分类（DashScope qwen3-vl-plus） ────────────────────────────
# API 限制：RPM=3000, TPM=5,000,000（触发任一即限流）
# VLM_CONCURRENCY       VLM 图片分类+描述的并发线程数
# ZHIPU_OCR_CONCURRENCY 智谱 OCR 的最大并发数（Semaphore 控制，独立于 VLM）
#                       VLM 判定为扫描件/表格时会追加调用 OCR，两者串联但各自限流
VLM_MODEL=qwen3-vl-plus
VLM_CONCURRENCY=10
ZHIPU_OCR_CONCURRENCY=5

# ── 阶段 2a 文件级提取并发 ─────────────────────────────────────────────
# 控制 align_evidence.py 阶段 2a 同时提取多少个文件。
# 文件级并发让多个文件的 API 调用（VLM/OCR）重叠等待，显著缩短总时间。
# 内部 VLM/OCR 各有独立并发限制（VLM_CONCURRENCY / ZHIPU_OCR_CONCURRENCY），
# 不会因文件级并发而超出 API 限流。
EXTRACT_CONCURRENCY=5

# ── Reranker 精排服务（DashScope qwen3-rerank）─────────────────────────
# API 限制：RPM=5400，单次最多 500 文档
# RERANKER_CONCURRENCY  并发请求数（119 个章节各自独立调用 rerank）
# RERANKER_BASE_URL=http://localhost:8083
RERANKER_MODEL=qwen3-rerank
RERANKER_CONCURRENCY=10

# ── LLM API（撰稿 / 查询生成） ─────────────────────────────────────────
# 通过 OpenAI 兼容接口调用，需自行部署或使用第三方服务
# LLM_BASE_URL=http://127.0.0.1:8000
# LLM_API_KEY=sk-leoi-888
# LLM_MODEL=deepseek-thinking
# LLM_TIMEOUT=180              # 查询生成单次请求超时（秒），默认 180
# DRAFT_LLM_TIMEOUT=120        # 初稿撰写单次请求超时（秒），默认 120
