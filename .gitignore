# ── 企业项目数据（各项目的原始资料 + 处理缓存，体积大且含敏感数据） ───────────
projects/*/raw/
projects/*/processed/

# ── data/ 目录（开发测试数据，不提交；仅放行框架模板） ─────────────────────────
data/
!data/raw/ESG报告框架.xlsx

# ── 输出目录 ──────────────────────────────────────────────────────────────────
output/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── Pipeline 进度文件（Python 写入，Node.js 轮询） ────────────────────────────
src/.progress/

# ── ChromaDB 向量数据库 ───────────────────────────────────────────────────────
.chroma_db/
.chroma_db_test/

# ── 实验目录（结果文件含真实数据） ───────────────────────────────────────────
experiments/pdf_classification/labeled/
experiments/pdf_classification/results/
experiments/vlm/results/
experiments/paddle/cells.json
experiments/paddle/cells_vis.png

# ── 临时工作目录 ──────────────────────────────────────────────────────────────
temp/

# ── Web 平台 ──────────────────────────────────────────────────────────────────
web/node_modules/
web/.next/
web/tsconfig.tsbuildinfo
# web/data/ 目录下的忽略规则由 web/data/.gitignore 管理
# 保留目录占位符，确保新环境 clone 后 web/data/ 目录存在
!web/data/.gitkeep
!web/data/.gitignore

# ── 环境变量（含 API Key，不提交） ────────────────────────────────────────────
.env
.env.local
.env.production

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── IDE / 编辑器 ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 系统文件 ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
