# ── 数据目录（原始资料 + 处理缓存，体积大） ─────────────────────────────
# 排除所有 data/ 目录，但以下路径单独处理
data/
!web/data/
!web/src/app/api/data/
!web/src/app/api/pipeline/data/

# ── 多企业项目数据目录（各企业的 raw/ 和 processed/，体积大） ────────────
# 仅忽略数据文件，projects/ 目录结构本身可提交（用于记录项目约定）
projects/*/raw/
projects/*/processed/

# ── 临时实验目录（OCR 对比测试生成的结果文件） ───────────────────────────
temp/result_*
temp/result_method2_full/
temp/__pycache__/

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── Pipeline 进度文件（Python 写入，Node.js 轮询） ──────────────────────
src/.progress/

# ── Web 平台 ──────────────────────────────────────────────────────────────
web/node_modules/
web/.next/
# web/data/ 目录下的忽略规则由 web/data/.gitignore 管理
# 保留目录占位符，确保新环境 clone 后 web/data/ 目录存在
!web/data/.gitkeep
!web/data/.gitignore

# ── ChromaDB 向量数据库 ──────────────────────────────────────────────────
.chroma_db/
.chroma_db_test/

# ── Claude Code ──────────────────────────────────────────────────────────
.claude/

# ── IDE / 编辑器 ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 环境变量（含 API Key，不提交） ───────────────────────────────────────
.env
.env.local
.env.production

# ── 系统文件 ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
web/tsconfig.tsbuildinfo
